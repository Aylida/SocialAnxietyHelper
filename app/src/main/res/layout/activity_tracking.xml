<?xml version="1.0" encoding="utf-8"?>
<!--
    Takip  ·  Redesign
    Stil: pastel kart arka planlar, büyük bold %,
    pill tab bar, lime aktif nav
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBg">

    <!-- ════════════════════════════════════════════════════════
         HEADER
         ════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Büyük bold başlık — referans: 26sp bold -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Takip"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <!-- Seri pill — referans: sarı kenarlıklı pill badge -->
        <TextView
            android:id="@+id/txtStreakBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 🔥"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/textOnAccent"
            android:background="@drawable/pill_green_solid"
            android:paddingHorizontal="16dp"
            android:paddingVertical="7dp"/>
    </LinearLayout>

    <!-- ════════════════════════════════════════════════════════
         TAB BAR  — referans: segmented pill (Haftalık/Aylık/Yıllık)
         ════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/tab_bg_rounded"
        android:orientation="horizontal"
        android:padding="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <TextView
            android:id="@+id/tabWeekly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/tab_active_bg"
            android:gravity="center"
            android:paddingVertical="9dp"
            android:text="Haftalık"
            android:textColor="@color/textPrimary"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tabMonthly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="9dp"
            android:text="Aylık"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tabYearly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="9dp"
            android:text="Yıllık"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ════════════════════════════════════════════════════════
         SCROLL CONTENT
         ════════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tabBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ─── HAFTALIK VIEW ─────────────────────────────── -->
            <LinearLayout
                android:id="@+id/viewWeekly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Hafta navigasyon satırı -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/btnPrevWeek"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/btn_circle_gray"
                        android:gravity="center"
                        android:text="&#8249;"
                        android:textColor="@color/textSecondary"
                        android:textSize="18sp"/>

                    <TextView
                        android:id="@+id/txtWeekLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"/>

                    <TextView
                        android:id="@+id/btnNextWeek"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/btn_circle_gray"
                        android:gravity="center"
                        android:text="&#8250;"
                        android:textColor="@color/textSecondary"
                        android:textSize="18sp"/>
                </LinearLayout>

                <!-- Gün ismi satırı -->
                <LinearLayout
                    android:id="@+id/weekDayRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="6dp"/>

                <!-- ── BÜYÜK STAT KARTI ─────────────────────── -->
                <!--
                    Referans: "24" gibi büyük rakam + pastel kart
                    Pastel yeşil arka plan
                -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/pastelGreen">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Yüzde + ring -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <!-- Referans: "03 / 05" büyük bold sayılar -->
                                <TextView
                                    android:id="@+id/txtWeekRate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textSize="56sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/textPrimary"
                                    android:letterSpacing="-0.02"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="HAFTALIK BAŞARI"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/textSecondary"
                                    android:letterSpacing="0.1"/>
                            </LinearLayout>

                            <FrameLayout
                                android:id="@+id/ringContainer"
                                android:layout_width="68dp"
                                android:layout_height="68dp"/>
                        </LinearLayout>

                        <!-- Bar chart -->
                        <LinearLayout
                            android:id="@+id/barChartContainer"
                            android:layout_width="match_parent"
                            android:layout_height="88dp"
                            android:orientation="horizontal"
                            android:gravity="bottom"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Mini stat kartları -->
                <LinearLayout
                    android:id="@+id/statsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Alışkanlıklar başlığı -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alışkanlıklar"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="10dp"/>

                <!-- Alışkanlık listesi -->
                <LinearLayout
                    android:id="@+id/habitsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="16dp"/>

                <!-- Kendin ekle — dashed pill (referans "Swipe Now" tonu) -->
                <LinearLayout
                    android:id="@+id/btnAddHabit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/btn_dashed_soft"
                    android:paddingVertical="15dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Kendin ekle"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textSecondary"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ─── AYLIK VIEW ─────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/viewMonthly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/btnPrevMonth"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/btn_circle_gray"
                        android:gravity="center"
                        android:text="&#8249;"
                        android:textSize="18sp"
                        android:textColor="@color/textSecondary"/>

                    <TextView
                        android:id="@+id/txtMonthLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"/>

                    <TextView
                        android:id="@+id/btnNextMonth"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/btn_circle_gray"
                        android:gravity="center"
                        android:text="&#8250;"
                        android:textSize="18sp"
                        android:textColor="@color/textSecondary"/>
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/pastelBlue">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:id="@+id/monthHabitTabs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="14dp"/>

                        <LinearLayout
                            android:id="@+id/monthDayHeaders"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp"/>

                        <android.widget.GridLayout
                            android:id="@+id/monthGrid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="7"/>

                        <LinearLayout
                            android:id="@+id/monthStats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="14dp"
                            android:paddingTop="14dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ─── YILLIK VIEW ───────────────────────────────── -->
            <LinearLayout
                android:id="@+id/viewYearly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/btnPrevYear"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/btn_circle_gray"
                        android:gravity="center"
                        android:text="&#8249;"
                        android:textSize="18sp"
                        android:textColor="@color/textSecondary"/>

                    <TextView
                        android:id="@+id/txtYearLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"/>

                    <TextView
                        android:id="@+id/btnNextYear"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/btn_circle_gray"
                        android:gravity="center"
                        android:text="&#8250;"
                        android:textSize="18sp"
                        android:textColor="@color/textSecondary"/>
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/pastelLavender">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <android.widget.GridLayout
                            android:id="@+id/yearGrid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="3"/>

                        <LinearLayout
                            android:id="@+id/yearScale"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginTop="12dp"/>

                        <LinearLayout
                            android:id="@+id/yearStats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="14dp"
                            android:paddingTop="14dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ════════════════════════════════════════════════════════
         BOTTOM NAV  — Takip AKTİF
         ════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/navBg"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Ana Sayfa -->
        <LinearLayout
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="30dp"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_home"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ana Sayfa"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <!-- Takip — AKTİF -->
        <LinearLayout
            android:id="@+id/btnNavTracking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="30dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/nav_active_bg">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_tracking"
                    app:tint="@color/navActiveIcon"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Takip"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/navActiveIcon"/>
        </LinearLayout>

        <!-- Bölümler — merkez siyah pill -->
        <LinearLayout
            android:id="@+id/btnNavWorlds"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="54dp"
                android:layout_height="34dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/nav_center_pill">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_world"
                    app:tint="#FFFFFF"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bölümler"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>
        </LinearLayout>

        <!-- Rehber Simit -->
        <LinearLayout
            android:id="@+id/btnNavChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="30dp"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_cat"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rehber"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <!-- Ayarlar -->
        <LinearLayout
            android:id="@+id/btnNavSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="30dp"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_settings"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ayarlar"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>