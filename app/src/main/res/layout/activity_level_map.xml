<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBgColor">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="12dp">
            <ImageView
                android:id="@+id/imgCharacter"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/avatarmaker_1"
                android:scaleType="centerCrop"
                android:background="@drawable/avatar_bg"/>
            <TextView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/pill_dark"
                android:text="3"
                android:textSize="8sp"
                android:textColor="#F9E04B"
                android:textStyle="bold"
                android:gravity="center"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="3dp">

                <TextView
                    android:id="@+id/txtPlayerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kahraman"
                    android:textSize="16sp"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/txtLevelBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seviye 1"
                    android:textSize="9sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/pill_pink"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="3dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/txtSeri"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 🔥"
                    android:textSize="11sp"
                    android:textColor="@color/textSecondary"
                    android:textStyle="bold"
                    android:background="@drawable/pill_outline"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressXP"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:id="@+id/txtXPInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 100 XP"
                android:textSize="9sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txtCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/pill_dark"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:textColor="#F9E04B"
            android:textSize="11sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- BÖLÜM BAŞLIĞI -->
    <LinearLayout
        android:id="@+id/sectionHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="10dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtWorldTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Görevler"
                android:textColor="@color/textPrimary"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txtWorldTopic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/textSecondary"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- STATUS ROW -->
    <HorizontalScrollView
        android:id="@+id/statusScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="10dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/sectionHeader"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/statusRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp"/>
    </HorizontalScrollView>

    <!-- CARD STACK -->
    <FrameLayout
        android:id="@+id/cardStack"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/statusScroll"
        app:layout_constraintBottom_toTopOf="@id/btnRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardBg2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_marginHorizontal="22dp"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/cardBg"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardBg1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="9dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/cardBg"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardTop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-30dp"
                    android:layout_marginEnd="-30dp"
                    android:background="@drawable/deco_circle"
                    android:alpha="0.15"/>

                <TextView
                    android:id="@+id/txtSwipeHintRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="20dp"
                    android:text="TAMAM ✓"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:alpha="0"
                    android:rotation="-15"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/hint_badge_green"/>

                <TextView
                    android:id="@+id/txtSwipeHintLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="20dp"
                    android:text="ATLA →"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B35"
                    android:alpha="0"
                    android:rotation="15"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/hint_badge_orange"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="26dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:id="@+id/txtTaskNo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="10sp"
                            android:textColor="#FFFFFF"
                            android:letterSpacing="0.2"
                            android:textStyle="bold"
                            android:alpha="0.7"/>

                        <TextView
                            android:id="@+id/txtRepeatBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/pill_semitransparent"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="5dp"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:alpha="0.8"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtTaskTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="28sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.2"
                        android:layout_marginBottom="14dp"/>

                    <TextView
                        android:id="@+id/txtTaskDesc"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:alpha="0.85"
                        android:lineSpacingMultiplier="1.6"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="14dp">

                        <LinearLayout
                            android:id="@+id/pipRow"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"/>

                        <TextView
                            android:id="@+id/txtSwipeHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="sağa kaydır →"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/pill_semitransparent"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="7dp"
                            android:alpha="0.7"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <!-- BUTONLAR -->
    <LinearLayout
        android:id="@+id/btnRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:text="✕"
            android:textSize="20sp"
            android:textColor="#FF4F4F"
            android:gravity="center"
            android:background="@drawable/btn_circle_red"
            android:layout_marginEnd="20dp"/>

        <TextView
            android:id="@+id/btnDone"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:text="✓"
            android:textSize="26sp"
            android:textColor="#F9E04B"
            android:gravity="center"
            android:background="@drawable/btn_circle_dark"
            android:layout_marginEnd="20dp"/>

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:text="↩"
            android:textSize="20sp"
            android:textColor="#999999"
            android:gravity="center"
            android:background="@drawable/btn_circle_gray"/>
    </LinearLayout>

    <!-- ALT NAV BAR -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/navBg"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:layout_marginBottom="5dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_home"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ana Sayfa"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavTracking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:layout_marginBottom="5dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_tracking"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Takip"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavWorlds"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="36dp"
                android:background="@drawable/nav_center_pill"
                android:layout_marginBottom="5dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_world"
                    app:tint="#FFFFFF"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bölümler"
                android:textSize="10sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:layout_marginBottom="5dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_cat"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rehber Simit"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:layout_marginBottom="5dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_settings"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ayarlar"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>