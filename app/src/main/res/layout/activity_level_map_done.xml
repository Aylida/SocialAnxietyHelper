<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5C842">

    <!-- Dekoratif arka plan dairesi (üst sağ) -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/deco_circle"
        android:alpha="0.15"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Dekoratif daire (sol alt) -->
    <View
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/deco_circle"
        android:alpha="0.10"
        android:layout_marginBottom="-40dp"
        android:layout_marginStart="-40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Ana içerik -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Rozet / trofeo -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/circle_white_shadow"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🏆"
                android:textSize="60sp"
                android:gravity="center"/>
        </FrameLayout>

        <!-- Tebrik başlığı -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦  TEBRİKLER  ✦"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5C4A00"
            android:letterSpacing="0.18"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/txtDoneTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bölümü Tamamladın!"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#3A2E00"
            android:fontFamily="serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.15"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/txtDoneSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Harika iş çıkardın. Cesaretin her adımda büyüyor."
            android:textSize="14sp"
            android:textColor="#7A6200"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="32dp"/>

        <!-- İstatistik kartı -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp">

                <!-- XP kazanıldı -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/txtXpEarned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+50"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#E07040"
                        android:fontFamily="serif"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XP Kazanıldı"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Ayırıcı -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#F0EDE6"
                    android:layout_marginVertical="4dp"/>

                <!-- Tamamlanan görev -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/txtTasksDone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#5C9E6E"
                        android:fontFamily="serif"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Görev"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Ayırıcı -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#F0EDE6"
                    android:layout_marginVertical="4dp"/>

                <!-- Seri -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/txtStreakDone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 12"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:fontFamily="serif"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Günlük Seri"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tekrar Oyna butonu -->
        <LinearLayout
            android:id="@+id/btnReplay"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_pink_rounded"
            android:elevation="4dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↩  TEKRAR OYNA"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"/>
        </LinearLayout>

        <!-- Sonraki bölüme git butonu -->
        <LinearLayout
            android:id="@+id/btnNextWorld"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_circle_dark"
            android:elevation="4dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HAYDİ DEVAM  →"
                android:textColor="#F9E04B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"/>
        </LinearLayout>

        <!-- Ana sayfaya dön -->
        <TextView
            android:id="@+id/btnGoHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ana sayfaya dön"
            android:textSize="13sp"
            android:textColor="#7A6200"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
