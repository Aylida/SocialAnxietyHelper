<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="?attr/appBgColor">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✏️"
        android:textSize="48sp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ADIM 1 / 3"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="?attr/textSecondaryColor"
        android:letterSpacing="0.12"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sana nasıl\nseslenelim?"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?attr/textPrimaryColor"
        android:lineSpacingMultiplier="1.2"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="İstediğin zaman ayarlardan değiştirebilirsin."
        android:textSize="13sp"
        android:textColor="?attr/textSecondaryColor"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="İsmin..."
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/textPrimaryColor"
        android:background="@drawable/input_normal"
        android:padding="16dp"
        android:maxLength="20"
        android:inputType="textPersonName"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/txtNameCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 / 20"
        android:textSize="11sp"
        android:textColor="?attr/textSecondaryColor"
        android:gravity="end"
        android:layout_marginTop="8dp"/>
</LinearLayout>