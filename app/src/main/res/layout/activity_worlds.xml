<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBg">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CESARET YOLCULUĞU"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/textSecondary"
                android:letterSpacing="0.15"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hangi dünyaya adım atıyorsun?"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:layout_marginTop="3dp"
                android:lineSpacingMultiplier="1.1"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="12dp">

            <!-- Avatar: oval CardView + ImageView, txtCharEmoji kaldırıldı -->
            <androidx.cardview.widget.CardView
                android:layout_width="62dp"
                android:layout_height="62dp"
                app:cardCornerRadius="31dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/cardBgColor">
                <ImageView
                    android:id="@+id/imgCharAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/avatarmaker_1"
                    android:scaleType="centerCrop"/>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="5dp">
                <TextView
                    android:id="@+id/txtAnchors"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚓ 0"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:background="@drawable/pill_white"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:id="@+id/txtStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 0"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:background="@drawable/pill_white"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Kategori tabları -->
    <HorizontalScrollView
        android:id="@+id/tabsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Scroll + kartlar -->
    <ScrollView
        android:id="@+id/worldsScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tabsScroll"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent">
        <LinearLayout
            android:id="@+id/cardsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"/>
    </ScrollView>

    <!-- ALT NAV BAR -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/navBg"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout android:id="@+id/btnNavHome"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp"
                android:layout_marginBottom="5dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_home"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ana Sayfa" android:textSize="10sp" android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnNavTracking"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp"
                android:layout_marginBottom="5dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_tracking"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Takip" android:textSize="10sp" android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <!-- Bölümler — AKTİF -->
        <LinearLayout android:id="@+id/btnNavWorlds"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="36dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/nav_active_bg">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_world"
                    app:tint="@color/colorPrimary" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bölümler"
                android:textColor="@color/colorPrimary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btnNavChat"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp"
                android:layout_marginBottom="5dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_cat"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Rehber Simit" android:textSize="10sp" android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnNavSettings"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp"
                android:layout_marginBottom="5dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_settings"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ayarlar" android:textSize="10sp" android:textColor="@color/textSecondary"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>