<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBgColor">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="36dp"
        android:paddingTop="14dp"
        android:background="?attr/appBgColor"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txtStep"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="?attr/textSecondaryColor"
                android:letterSpacing="0.12"/>

            <TextView
                android:id="@+id/txtStepDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="?attr/textSecondaryColor"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@drawable/progress_bg"
            android:layout_marginBottom="16dp">
            <View
                android:id="@+id/progressFill"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/progress_fill"
                android:scaleX="0.001"
                android:transformPivotX="0dp"/>
        </FrameLayout>

        <TextView
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Devam Et →"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#F9E04B"
            android:gravity="center"
            android:background="@drawable/pill_dark"
            android:paddingVertical="16dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>