<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBg">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="52dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/txtDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoş geldin"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"/>

                <TextView
                    android:id="@+id/txtWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bugün bir\nadım at"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.1"
                    android:textColor="@color/textPrimary"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- ── SERİ + AVATAR ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">

                <!-- Büyük seri sayısı -->
                <TextView
                    android:id="@+id/txtStatSeri"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:includeFontPadding="false"/>

                <!-- Badge -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/txtStreakBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/pill_lime"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="5dp"
                        android:text="GÜNLÜK SERİ"
                        android:textColor="#1A1A1A"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Avatar daireleri + "Bu hafta aktif" altında -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <androidx.cardview.widget.CardView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            app:cardCornerRadius="17dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#4CAF50">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="A"
                                android:gravity="center"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"/>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="-10dp"
                            app:cardCornerRadius="17dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#2196F3">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="K"
                                android:gravity="center"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"/>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="-10dp"
                            app:cardCornerRadius="17dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#E0E0E0">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="+3"
                                android:gravity="center"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/textPrimary"/>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bu hafta aktif"
                        android:textSize="10sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── 4 STAT SATIRI ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp">

                <!-- Tamamlanan -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txtStatGorev"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="42"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorStreak"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tamamlanan"
                        android:textSize="10sp"
                        android:textColor="@color/textSecondary"/>
                </LinearLayout>

                <!-- Çapa -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txtStatKristal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorAnchor"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Çapa"
                        android:textSize="10sp"
                        android:textColor="@color/textSecondary"/>
                </LinearLayout>

                <!-- Seviye -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txtLevelCurrent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#E91E63"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seviye"
                        android:textSize="10sp"
                        android:textColor="@color/textSecondary"/>
                </LinearLayout>

                <!-- XP -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txtXPInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="620"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XP"
                        android:textSize="10sp"
                        android:textColor="@color/textSecondary"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── XP BAR ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="20dp">

                <ProgressBar
                    android:id="@+id/progressXP"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:max="100"
                    android:progress="62"
                    android:progressBackgroundTint="#E0E0E0"
                    android:progressTint="@color/colorPrimary"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seviye 5 → 6"
                        android:textSize="10sp"
                        android:textColor="@color/textSecondary"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/txtLevelNext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="620 / 1000 XP"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── 2x2 GRID KARTLAR ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp">

                <!-- Üst sıra -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- Bölümler -->
                    <LinearLayout
                        android:id="@+id/cardWorlds"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/card_pastel_dark"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_nav_world"
                            app:tint="@color/cardBg"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bölümler"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/cardBg"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6 kategori"
                            android:textSize="11sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <!-- Rehber -->
                    <LinearLayout
                        android:id="@+id/cardChat"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:background="@drawable/card_turkuaz"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_nav_chat"
                            app:tint="@color/cardBg"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rehber"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/cardBg"/>

                        <TextView
                            android:id="@+id/txtChatStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sohbet et"
                            android:textSize="11sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Alt sıra -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Takip -->
                    <LinearLayout
                        android:id="@+id/cardtracking"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/card_kirmizi"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_nav_tracking"
                            app:tint="@color/cardBg"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Takip"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/cardBg"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alışkanlıklar"
                            android:textSize="11sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <!-- Nasılsın? -->
                    <LinearLayout
                        android:id="@+id/cardMood"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:background="@drawable/card_sari"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_nav_howareu"
                            app:tint="@color/cardBg"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nasılsın?"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/cardBg"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sorunum var"
                                android:textSize="9sp"
                                android:textColor="#CCCCCC"
                                android:background="@drawable/pill_yellow_2"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="3dp"
                                android:layout_marginEnd="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kaygılıyım"
                                android:textSize="9sp"
                                android:textColor="#CCCCCC"
                                android:background="@drawable/pill_yellow_2"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="3dp"
                                android:layout_marginEnd="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="İyiyim!"
                                android:textSize="9sp"
                                android:textColor="#CCCCCC"
                                android:background="@drawable/pill_yellow_2"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="3dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- GÖREVLER başlığı -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GÖREVLER"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/textSecondary"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"/>

            <!-- Dinamik görev listesi (Java tarafından doldurulur) -->
            <LinearLayout
                android:id="@+id/taskListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"/>

            <!-- Görev 1 — statik örnek -->
            <LinearLayout
                android:id="@+id/activeTaskCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="4dp"
                android:background="@color/cardBg"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_green"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtTaskName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toplantıda söz al"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"/>

                    <TextView
                        android:id="@+id/txtWorldLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="İş · Bölüm 1"
                        android:textSize="11sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_star_filled" app:tint="@color/colorPrimary"
                        android:layout_marginStart="2dp"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_star_filled" app:tint="@color/colorPrimary"
                        android:layout_marginStart="2dp"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_star_outline" app:tint="#CCCCCC"
                        android:layout_marginStart="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Görev 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="4dp"
                android:background="@color/cardBg"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_pink"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Göz teması kur"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Romantik · Bölüm 2"
                        android:textSize="11sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_star_filled" app:tint="#E91E63"
                        android:layout_marginStart="2dp"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_star_outline" app:tint="#CCCCCC"
                        android:layout_marginStart="2dp"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_star_outline" app:tint="#CCCCCC"
                        android:layout_marginStart="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Görev 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:background="@color/cardBg"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_yellow"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Asansörde selam ver"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Genel · Bölüm 3"
                        android:textSize="11sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_star_filled" app:tint="#FF9800"
                        android:layout_marginStart="2dp"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_star_outline" app:tint="#CCCCCC"
                        android:layout_marginStart="2dp"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_star_outline" app:tint="#CCCCCC"
                        android:layout_marginStart="2dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── BOTTOM NAV ── -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/navBg"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Ana Sayfa — AKTİF -->
        <LinearLayout
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="30dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/nav_active_bg">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_home"
                    app:tint="@color/navActiveIcon"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sayfa"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/navActiveIcon"/>
        </LinearLayout>

        <!-- Takip -->
        <LinearLayout
            android:id="@+id/btnNavtracking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="30dp"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_tracking"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Takip"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <!-- Bölümler — merkez pill -->
        <LinearLayout
            android:id="@+id/btnNavWorlds"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="54dp"
                android:layout_height="34dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/nav_center_pill">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_world"
                    app:tint="#FFFFFF"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bölümler"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>
        </LinearLayout>

        <!-- Rehber -->
        <LinearLayout
            android:id="@+id/btnNavChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="30dp"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_chat"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rehber"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <!-- Ayarlar -->
        <LinearLayout
            android:id="@+id/btnNavSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="30dp"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_settings"
                    app:tint="@color/textSecondary"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ayarlar"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>